generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Allergene {
  id                String              @id
  nome              String              @unique
  descrizione       String?
  icona             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  AllergeneArticolo AllergeneArticolo[]
}

model AllergeneArticolo {
  id          String    @id
  articoloId  String
  allergeneId String
  Allergene   Allergene @relation(fields: [allergeneId], references: [id], onDelete: Cascade)
  Articolo    Articolo  @relation(fields: [articoloId], references: [id], onDelete: Cascade)

  @@unique([articoloId, allergeneId])
}

model AnalyticsDaily {
  id                 String   @id
  date               DateTime @unique
  totalVisits        Int      @default(0)
  uniqueVisitors     Int      @default(0)
  pageViews          String?
  avgSessionDuration Int      @default(0)
  hourlyBreakdown    String?
  topPages           String?
  productViews       String?
  conversionData     String?
  createdAt          DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id
  sessionId String
  eventType String
  pageUrl   String
  productId String?
  duration  Int?
  referrer  String?
  userAgent String?
  ipHash    String?
  country   String?
  city      String?
  timestamp DateTime @default(now())
}

model AnalyticsMonthly {
  id              String   @id
  month           String
  year            Int
  totalVisits     Int      @default(0)
  uniqueVisitors  Int      @default(0)
  avgDailyVisits  Float    @default(0)
  bestDayOfWeek   String?
  bestHourOfDay   Int?
  avgWeeklyVisits Float    @default(0)
  growthRate      Float    @default(0)
  productInsights String?
  priceInsights   String?
  createdAt       DateTime @default(now())
}

model AnalyticsWeekly {
  id                 String   @id
  weekStartDate      DateTime
  weekEndDate        DateTime
  totalVisits        Int      @default(0)
  uniqueVisitors     Int      @default(0)
  avgDailyVisits     Float    @default(0)
  bestDayOfWeek      String?
  bestHourOfDay      Int?
  topProducts        String?
  conversionInsights String?
  priceInsights      String?
  createdAt          DateTime @default(now())
}

model AnalyticsYearly {
  id               String   @id
  year             Int      @unique
  totalVisits      Int      @default(0)
  uniqueVisitors   Int      @default(0)
  avgMonthlyVisits Float    @default(0)
  bestMonth        String?
  overallTrend     String?
  productInsights  String?
  priceInsights    String?
  createdAt        DateTime @default(now())
}

model Articolo {
  id                 String              @id
  nome               String
  descrizione        String?
  categoriaId        String
  prezzo             Float
  prezzoPromozionale Float?
  scadenzaPromo      DateTime?
  eSurgelato         Boolean             @default(false)
  eBestChoice        Boolean             @default(false)
  attivo             Boolean             @default(true)
  immagineUrl        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  immagineAiGenerata Boolean             @default(false)
  AllergeneArticolo  AllergeneArticolo[]
  Categoria          Categoria           @relation(fields: [categoriaId], references: [id])
}

model BannerPubblicitario {
  id           String   @id
  tipo         String
  posizione    String
  sponsorNome  String
  sponsorLogo  String?
  sponsorUrl   String
  titolo       String?
  descrizione  String?
  ctaTesto     String?
  ctaUrl       String?
  immagineUrl  String?
  coloreSfondo String?
  attivo       Boolean  @default(true)
  ordine       Int      @default(0)
  pagine       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model Categoria {
  id        String     @id
  nome      String     @unique
  ordine    Int        @default(0)
  attiva    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Articolo  Articolo[]
}

model CompanyData {
  id                       String    @id
  ragioneSociale           String?
  partitaIva               String?
  privacyPolicy            String?
  cookiesPolicy            String?
  terminiServizio          String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime
  cap                      String?
  citta                    String?
  codiceFiscale            String?
  cookieAcceptText         String?   @default("Autorizzo")
  cookieAnalitici          Boolean   @default(true)
  cookieBannerText         String?   @default("Questo sito utilizza cookie tecnici e analitici per migliorare la tua esperienza di navigazione. Cliccando su 'Autorizzo', accetti l'uso dei cookie.")
  cookieDeclineText        String?   @default("Annulla")
  cookieMarketing          Boolean   @default(true)
  cookieTecnici            Boolean   @default(true)
  cookiesEnabled           Boolean   @default(true)
  cookiesPolicyUpdate      DateTime?
  cookiesUrl               String?
  dpoEmail                 String?
  dpoIndirizzo             String?
  dpoNome                  String?
  email                    String?
  indirizzo                String?
  paese                    String?
  pec                      String?
  privacyEnabled           Boolean   @default(true)
  privacyPolicyUpdate      DateTime?
  privacyUrl               String?
  provincia                String?
  showCookieBanner         Boolean   @default(true)
  telefono                 String?
  terminiUrl               String?
  amazonTagId              String?
  facebookPixelId          String?
  googleAnalyticsId        String?
  thirdPartyScriptsEnabled Boolean   @default(true)
  adSenseId                String?
  adSenseSlotHorizontal    String?
  adSenseSlotInline        String?
  adSenseSlotRectangle     String?
  adSenseSlotTop           String?
}

model I18nSettings {
  id                String   @id @default("default")
  multilinguaAttivo Boolean  @default(false)
  enAttivo          Boolean  @default(false)
  frAttivo          Boolean  @default(false)
  deAttivo          Boolean  @default(false)
  esAttivo          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TranslationCache {
  id              String   @id
  chiave          String
  locale          String
  testoOriginale  String
  testoTradotto   String
  sezione         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([chiave, locale])
}

model Evento {
  id                  String        @id
  titolo              String
  slug                String        @unique
  descrizione         String
  descrizioneBreve    String
  immagineUrl         String?
  data                DateTime
  oraInizio           String
  oraFine             String
  prezzo              Float         @default(0)
  etichettaPrezzo     String?
  capacita            Int           @default(0)
  postiDisponibili    Int           @default(0)
  location            String?
  incluso             String?
  infoAggiuntive      String?
  attivo              Boolean       @default(true)
  ricorrente          Boolean       @default(false)
  giorniRicorrenza    String?
  inEvidenza          Boolean       @default(false)
  nuovo               Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime
  graditaPrenotazione Boolean       @default(false)
  gratuito            Boolean       @default(false)
  Reservation         Reservation[]
}

model FooterInfo {
  id             String   @id
  indirizzo      String?
  citta          String?
  cap            String?
  provincia      String?
  latitudine     Float?
  longitudine    Float?
  orariApertura  String?
  giorniChiusura String?
  facebookUrl    String?
  instagramUrl   String?
  twitterUrl     String?
  linkedinUrl    String?
  whatsappUrl    String?
  tiktokUrl      String?
  justeatUrl     String?
  deliverooUrl   String?
  glovoUrl       String?
  ubereatsUrl    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  telefono       String?
}

model Permission {
  id                     String   @id
  userId                 String   @unique
  puoGestireMenu         Boolean  @default(true)
  puoGestireFooter       Boolean  @default(true)
  puoGestireTemi         Boolean  @default(true)
  puoGestirePrenotazioni Boolean  @default(true)
  puoGestireDatiAzienda  Boolean  @default(true)
  puoGestireProfili      Boolean  @default(false)
  puoGestireAnalytics    Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime
  puoGestireSito         Boolean  @default(true)
  puoGestireEventi       Boolean  @default(true)
  puoGestireCookiePrivacy Boolean @default(true)
  puoGestireBanners     Boolean  @default(true)
  puoGestireMultilingua Boolean  @default(true)
  User                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reservation {
  id        String   @id
  nome      String
  cognome   String
  email     String
  telefono  String
  data      String
  ora       String
  persone   Int
  tipologia  String   @default("ristorante")
  note      String?
  stato     String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime
  eventoId  String?
  Evento    Evento?  @relation(fields: [eventoId], references: [id])
}

model SiteImage {
  id          String   @id
  sezione     String
  titolo      String?
  descrizione String?
  url         String
  ordine      Int      @default(0)
  attiva      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model SiteInfo {
  id                 String   @id
  nomeLocale         String   @default("Il Nostro Ristorante")
  slogan             String?
  chiSiamoTitolo     String?
  chiSiamoTesto      String?
  chiSiamoImageUrl   String?
  logoUrl            String?
  faviconUrl         String?
  telefono           String?
  email              String?
  prenotazioniAttive Boolean  @default(true)
  heroTitle          String?  @default("Autentica Cucina Italiana")
  heroSubtitle       String?
  heroCTAText        String?  @default("Scopri il Menu")
  heroImageUrl       String?
  heroOverlayOpacity Float    @default(0.5)
  specialitaTitle    String?  @default("Le Nostre Specialità")
  specialitaSubtitle String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  seoCanonical       String?
  seoDescription     String?  @default("Modern Next.js scaffold optimized for AI-powered development with Z.ai. Built with TypeScript, Tailwind CSS, and shadcn/ui.")
  seoKeywords        String?  @default("Z.ai, Next.js, TypeScript, Tailwind CSS, shadcn/ui, AI development, React")
  seoOgDescription   String?
  seoOgImage         String?
  seoOgTitle         String?
  seoRobots          String?
  seoTitle           String?  @default("Z.ai Code Scaffold - AI-Powered Development")
  seoTwitterCard     String?  @default("summary_large_image")
  primaryColor       String?  @default("#ea580c")
  primaryForeground  String?  @default("#ffffff")
  secondaryColor     String?  @default("#0d9488")
  footerBgColor      String?  @default("#111827")
  footerTextColor    String?  @default("#d1d5db")
  sectionBgColor     String?  @default("#f9fafb")
  socialBtnColor     String?  @default("#ea580c")
  settingsBtnColor   String?  @default("#dc2626")
  prenotaBtnColor       String?  @default("#ea580c")
  prenotaSectionBgColor String?  @default("#ea580c")
  orarioPranzoInizio    String?  @default("12:00")
  orarioPranzoFine      String?  @default("14:30")
  orarioCenaInizio      String?  @default("19:00")
  orarioCenaFine        String?  @default("22:30")
  headingFont           String?  @default("Playfair Display")
  bodyFont           String?  @default("Inter")
}

model User {
  id         String      @id
  email      String      @unique
  nome       String
  cognome    String?
  password   String
  ruolo      String      @default("admin")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime
  Permission Permission?
}
