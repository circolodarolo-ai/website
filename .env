# ═══ PostgreSQL ════════════════════════════════════════════════════════
# Modifica utente, password e nome DB secondo la tua configurazione.
# Esempi:
#   DATABASE_URL="postgresql://postgres:miaPassword@localhost:5432/ristorante_db"
#   DATABASE_URL="postgresql://z:z@localhost:5432/ristorante_db"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ristorante_db"

# ═══ SQLite (vecchio, da usare solo per il dump dei dati) ═══════════
# Non cancellare questa riga finché non hai migrato i dati.
OLD_SQLITE_URL="file:./db/custom.db"